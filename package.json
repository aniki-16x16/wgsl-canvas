{
  "name": "wgsl-canvas",
  "displayName": "Wgsl Canvas",
  "description": "Preview WGSL shaders in a split webview panel.",
  "version": "1.0.0",
  "keywords": [
    "wgsl",
    "shader",
    "webgpu"
  ],
  "publisher": "aniki-16x16",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "wgslCanvas.openPreview",
        "title": "WGSL: Open Preview"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.19.42",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aniki-16x16/wgsl-canvas"
  },
  "license": "MIT"
}
